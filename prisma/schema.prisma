generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  passwordHash  String
  role          String   @default("editor")
  company       String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Project {
  id            String   @id @default(uuid())
  name          String
  number        String
  buildingType  String   @default("")
  grossArea     Float    @default(0)
  estimatedCost Float    @default(0)
  createdBy     String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  planFiles     PlanFile[]
  bimModels     BimModel[]
  schedules     Schedule[]
}

model PlanFile {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  filePath    String
  fileType    String   @default("image")
  sheetNumber String   @default("")
  discipline  String   @default("Architectural")
  revision    String   @default("0")
  setName     String   @default("Current")
  scale       Float    @default(100)
  analysis    String   @default("")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model Classification {
  id          String   @id @default(uuid())
  name        String
  category    String   @default("area")
  color       String   @default("rgba(59,130,246,0.25)")
  costCode    String   @default("")
  unitRate    Float    @default(0)
  unit        String   @default("SF")
  companyWide Boolean  @default(true)
  projectId   String   @default("")
  createdAt   DateTime @default(now())
}

model Assembly {
  id          String   @id @default(uuid())
  name        String
  category    String   @default("wall")
  unit        String   @default("SF")
  description String   @default("")
  components  String   @default("[]")
  totalCost   Float    @default(0)
  companyWide Boolean  @default(true)
  projectId   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SharedModel {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  filePath    String
  shareToken  String   @unique
  viewCount   Int      @default(0)
  createdBy   String   @default("")
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ─── 4D Construction Simulation ─────────────────────────────

model BimModel {
  id          String       @id @default(uuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  discipline  String       @default("Architectural")
  filePath    String
  fileSizeMb  Float        @default(0)
  elementCount Int         @default(0)
  uploadedAt  DateTime     @default(now())
  elements    BimElement[]
}

model BimElement {
  id          String       @id @default(uuid())
  modelId     String
  model       BimModel     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  globalId    String
  ifcClass    String       @default("")
  name        String       @default("")
  levelName   String       @default("")
  material    String       @default("")
  volume      Float        @default(0)
  area        Float        @default(0)
  properties  String       @default("{}")
  taskLinks   TaskElementLink[]

  @@unique([modelId, globalId])
}

model Schedule {
  id           String     @id @default(uuid())
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  sourceFormat String     @default("excel")
  version      Int        @default(1)
  importedAt   DateTime   @default(now())
  tasks        Task[]
}

model Task {
  id              String       @id @default(uuid())
  scheduleId      String
  schedule        Schedule     @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  externalId      String       @default("")
  wbsCode         String       @default("")
  name            String
  taskType        String       @default("task")
  startDate       DateTime
  endDate         DateTime
  durationDays    Float        @default(0)
  percentComplete Float        @default(0)
  parentTaskId    String?
  sortOrder       Int          @default(0)
  costBudget      Float        @default(0)
  costActual      Float        @default(0)
  elementLinks    TaskElementLink[]
  predecessors    TaskDependency[] @relation("successor")
  successors      TaskDependency[] @relation("predecessor")
}

model TaskDependency {
  id             String   @id @default(uuid())
  predecessorId  String
  predecessor    Task     @relation("predecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successorId    String
  successor      Task     @relation("successor", fields: [successorId], references: [id], onDelete: Cascade)
  depType        String   @default("FS")
  lagDays        Float    @default(0)

  @@unique([predecessorId, successorId])
}

model TaskElementLink {
  id          String     @id @default(uuid())
  taskId      String
  task        Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  elementId   String
  element     BimElement @relation(fields: [elementId], references: [id], onDelete: Cascade)
  action      String     @default("construct")
  createdBy   String     @default("manual")

  @@unique([taskId, elementId])
}

model DailyLog {
  id          String   @id @default(uuid())
  projectId   String
  date        DateTime
  taskId      String?
  description String   @default("")
  progress    Float    @default(0)
  weather     String   @default("")
  crew        Int      @default(0)
  notes       String   @default("")
  photos      String   @default("[]")
  createdBy   String   @default("")
  createdAt   DateTime @default(now())
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  passwordHash  String
  role          String   @default("editor")
  company       String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Project {
  id            String   @id @default(uuid())
  name          String
  number        String
  buildingType  String   @default("")
  grossArea     Float    @default(0)
  estimatedCost Float    @default(0)
  createdBy     String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  planFiles     PlanFile[]
}

model PlanFile {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  filePath    String
  fileType    String   @default("image")
  sheetNumber String   @default("")
  discipline  String   @default("Architectural")
  revision    String   @default("0")
  setName     String   @default("Current")
  scale       Float    @default(100)
  analysis    String   @default("")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model Classification {
  id          String   @id @default(uuid())
  name        String
  category    String   @default("area")
  color       String   @default("rgba(59,130,246,0.25)")
  costCode    String   @default("")
  unitRate    Float    @default(0)
  unit        String   @default("SF")
  companyWide Boolean  @default(true)
  projectId   String   @default("")
  createdAt   DateTime @default(now())
}

model Assembly {
  id          String   @id @default(uuid())
  name        String
  category    String   @default("wall")
  unit        String   @default("SF")
  description String   @default("")
  components  String   @default("[]")
  totalCost   Float    @default(0)
  companyWide Boolean  @default(true)
  projectId   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SharedModel {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  filePath    String
  shareToken  String   @unique
  viewCount   Int      @default(0)
  createdBy   String   @default("")
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
}
